// Tracker Liberty — schema principal (multi-tenant)
generator client {
  provider     = "prisma-client"
  output       = "../generated/prisma"
  moduleFormat = "cjs"
  runtime      = "nodejs"
}

datasource db {
  provider = "postgresql"
}

enum WorkspaceRole {
  OWNER
  ADMIN
  MEMBER
}

enum Platform {
  META
  GA4
  GOOGLE_ADS // reservado para a fase 2 (exige Developer Token do Google Ads)
}

enum EventType {
  PAGE_VIEW
  WHATSAPP_CLICK
  LEAD
  PURCHASE
  SUBSCRIPTION
  CUSTOM
  HEARTBEAT
}

enum ForwardStatus {
  PENDING
  SUCCESS
  FAILED
  SKIPPED
}

model Workspace {
  id        String    @id @default(cuid())
  name      String
  slug      String    @unique
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  users     User[]
  projects  Project[]
}

model User {
  id           String        @id @default(cuid())
  email        String        @unique
  passwordHash String
  name         String?
  role         WorkspaceRole @default(OWNER)
  workspaceId  String
  workspace    Workspace     @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt

  @@index([workspaceId])
}

model Project {
  id               String    @id @default(cuid())
  workspaceId      String
  workspace        Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  name             String
  slug             String
  apiKeyHash       String    @unique
  apiKeyEncrypted  String
  waPhoneNumber    String?
  waDefaultMessage String?
  domain           String?
  trackerConfig    Json?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  credentials PlatformCredential[]
  events      Event[]
  visitors    Visitor[]

  @@unique([workspaceId, slug])
  @@index([workspaceId])
}

model PlatformCredential {
  id                String    @id @default(cuid())
  projectId         String
  project           Project   @relation(fields: [projectId], references: [id], onDelete: Cascade)
  platform          Platform
  encryptedPayload  String
  metaTestEventCode String?
  isActive          Boolean   @default(true)
  lastVerifiedAt    DateTime?
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  @@unique([projectId, platform])
}

model Event {
  id             String    @id @default(cuid())
  projectId      String
  project        Project   @relation(fields: [projectId], references: [id], onDelete: Cascade)
  visitorId      String
  sessionId      String?
  eventName      String
  eventType      EventType
  eventId        String
  occurredAt     DateTime
  sourceUrl      String?
  referrerUrl    String?
  utmSource      String?
  utmMedium      String?
  utmCampaign    String?
  utmTerm        String?
  utmContent     String?
  fbclid         String?
  gclid          String?
  ip             String?
  userAgent      String?
  emailEncrypted String?
  phoneEncrypted String?
  externalId     String?
  currency       String?
  value          Decimal?  @db.Decimal(12, 2)
  metadata       Json?
  isNewVisitor     Boolean?
  isNewSession     Boolean?
  sessionStartedAt DateTime?
  createdAt      DateTime  @default(now())

  forwards EventForward[]

  @@unique([projectId, eventId])
  @@index([projectId, occurredAt])
  @@index([projectId, visitorId])
}

/// Durable per-visitor aggregate (source of truth for attribution).
/// Complements the ephemeral Redis VisitorManager; never replaces it.
model Visitor {
  id               String    @id @default(cuid())
  projectId        String
  project          Project   @relation(fields: [projectId], references: [id], onDelete: Cascade)
  visitorId        String
  firstSeenAt      DateTime  @default(now())
  lastSeenAt       DateTime  @default(now())
  sessionCount     Int       @default(0)
  eventCount       Int       @default(0)
  clickIds         Json?
  firstTouch       Json?
  lastTouch        Json?
  context          Json?
  geo              Json?
  fingerprintHash  String?
  fingerprintVersion Int?
  convertedAt      DateTime?
  conversionCount  Int       @default(0)
  conversionValue  Decimal?  @db.Decimal(14, 2)
  attribution      Json?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  touchpoints Touchpoint[]

  @@unique([projectId, visitorId])
  @@index([projectId, lastSeenAt])
}

/// Append-only attribution timeline (channel touches + conversions).
/// Rows are NEVER updated — always inserted — so models can be recalculated
/// and journeys audited/replayed.
model Touchpoint {
  id           String    @id @default(cuid())
  projectId    String
  visitorId    String
  visitor      Visitor   @relation(fields: [projectId, visitorId], references: [projectId, visitorId], onDelete: Cascade)
  sessionId    String?
  occurredAt   DateTime
  position     Int
  source       String?
  medium       String?
  campaign     String?
  content      String?
  term         String?
  channel      String?
  referrer     String?
  landingPage  String?
  clickIds     Json?
  eventType    EventType
  eventName    String
  isConversion Boolean   @default(false)
  value        Decimal?  @db.Decimal(14, 2)
  createdAt    DateTime  @default(now())

  @@index([projectId, visitorId, occurredAt])
}

model EventForward {
  id              String        @id @default(cuid())
  eventId         String
  event           Event         @relation(fields: [eventId], references: [id], onDelete: Cascade)
  platform        Platform
  status          ForwardStatus @default(PENDING)
  attempt         Int           @default(0)
  requestPayload  Json?
  responsePayload Json?
  httpStatus      Int?
  errorMessage    String?
  sentAt          DateTime?
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  @@unique([eventId, platform])
}
