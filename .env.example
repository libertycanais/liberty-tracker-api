DATABASE_URL="postgresql://liberty:liberty@localhost:5432/liberty_tracker?schema=public"
REDIS_URL="redis://localhost:6379"
JWT_SECRET="replace-with-a-long-random-secret"
JWT_EXPIRES_IN="7d"
ENCRYPTION_KEY="replace-with-32-bytes-random-key"
PORT=3001
CORS_ORIGIN="http://localhost:3000"
META_API_VERSION="v21.0"

# Google Ads (fase 2) — conta MCC única da LibertyTechnology.
# Sem essas variáveis, o forwarder do Google Ads falha de forma controlada (FAILED),
# não derruba a aplicação. Ver checklist no README de como obter cada uma.
GOOGLE_ADS_DEVELOPER_TOKEN=
GOOGLE_ADS_CLIENT_ID=
GOOGLE_ADS_CLIENT_SECRET=
GOOGLE_ADS_REFRESH_TOKEN=
GOOGLE_ADS_LOGIN_CUSTOMER_ID=
GOOGLE_ADS_API_VERSION="v21"

# Production Hardening (Sprint 3.5) — todas opcionais, com defaults sensatos.
DEFAULT_PROJECT_RATE_LIMIT_PER_MINUTE=120
BODY_LIMIT="100kb"
# CSV de hostnames; vazio = reflete qualquer Origin (ver docs/SECURITY.md)
GLOBAL_ORIGIN_WHITELIST=
# Setadas pelo pipeline de CI/build; sem elas GET /version reporta "unknown"/o horário de start do processo
GIT_COMMIT=
BUILD_DATE=
# Feature flags locais — todas default true
ENABLE_TRACKER=true
ENABLE_FORWARDING=true
ENABLE_GOOGLE_ADS=true
ENABLE_META_CAPI=true
ENABLE_GA4=true
ENABLE_WEBHOOKS=true
ENABLE_SWAGGER=true
ENABLE_METRICS=true
ENABLE_HEALTH=true
